{
    "coc.preferences.formatOnSave": false,
    "coc.preferences.formatOnType": false,
    "diagnostic.locationlistUpdate": true,
    "diagnostic.enable": true,
    "diagnostic.enableMessage": "always",
    "diagnostic.messageTarget": "float",
    "diagnostic.floatConfig": {
        "border": true,
        "rounded": false,
        "highlight": "CocFloating",
        "borderhighlight": "CocFloatBorder"
    },
    "hover.floatConfig": {
        "border": true,
        "rounded": false,
        "highlight": "CocFloating",
        "borderhighlight": "CocFloatBorder"
    },
    "diagnostic.enableSign": false,
    "diagnostic.virtualText": true,
    "diagnostic.virtualTextAlign": "after",
    "diagnostic.virtualTextCurrentLineOnly": false,
    "diagnostic.refreshOnInsertMode": false,
    "pullDiagnostic.onChange": false,
    "diagnostic.infoSign": "💡",
    "diagnostic.errorSign": "🔥",
    "diagnostic.warningSign": "🔔",
    "clangd.arguments": [
        "--completion-style=bundled",
        "--function-arg-placeholders=1",
        "--header-insertion-decorators",
        "--all-scopes-completion=false"
    ],
    "inlayHint.enable": false,
    "inlayHint.enableParameter": false,
    "semanticTokens.enable": true,
    "suggest.localityBonus": true,
    "suggest.snippetIndicator": " ⚡",
    "suggest.noselect": true,
    "git.addedSign.hlGroup": "GitGutterAdd",
    "git.changedSign.hlGroup": "GitGutterChange",
    "git.removedSign.hlGroup": "GitGutterDelete",
    "git.topRemovedSign.hlGroup": "GitGutterDelete",
    "git.changeRemovedSign.hlGroup": "GitGutterChangeDelete"
}
